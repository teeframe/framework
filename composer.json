{
    "name": "teeframe/framework",
    "type": "project",
    "description": "The TeeFrame project.",
    "license": "MIT",
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "TeeFrame\\Core\\": "core/",
            "TeeFrame\\Game\\": "game/",
            "TeeFrame\\Map\\": "map/",
            "TeeFrame\\Network\\": "network/",
            "TeeFrame\\Server\\": "server/"
        }
    },
    "require": {
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "swoole/ide-helper": "^6.0",
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.7",
        "phpstan/phpstan": "^2.2"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
