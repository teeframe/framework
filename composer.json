{
    "name": "teeframe/framework",
    "type": "project",
    "description": "The TeeFrame project.",
    "license": "MIT",
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "TeeFrame\\Core\\": "core/",
            "TeeFrame\\Game\\": "game/",
            "TeeFrame\\Map\\": "map/",
            "TeeFrame\\Network\\": "network/",
            "TeeFrame\\Server\\": "server/"
        }
    },
    "require": {
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "swoole/ide-helper": "^5.1",
        "laravel/pint": "^1.13",
        "vimeo/psalm": "^5.21",
        "pestphp/pest": "^2.34"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
